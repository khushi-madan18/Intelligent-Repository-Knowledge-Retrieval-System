# Application
# Runtime environment: development, test, staging, or production.
APP_ENV=development
# Human-readable app name shown in docs and logs.
APP_NAME=Intelligent Repository Knowledge Retrieval System
# API version prefix.
API_V1_PREFIX=/api/v1
# Logging level: DEBUG, INFO, WARNING, ERROR, or CRITICAL.
LOG_LEVEL=INFO

# Repository ingestion
# Maximum repository size accepted by the ingestion pipeline.
MAX_REPO_SIZE_MB=100

# Database
# Async SQLAlchemy URL. SQLite is the default for local development.
DATABASE_URL=sqlite+aiosqlite:///./data/reporag.db
# Example async Postgres URL for Docker/production.
POSTGRES_DATABASE_URL=postgresql+asyncpg://reporag:reporag@postgres:5432/reporag

# Neo4j graph database
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
# Required secret in production.
NEO4J_PASSWORD=change-me

# Qdrant vector database
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=code_chunks

# LLM provider
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
# Required secret in production.
OPENAI_API_KEY=change-me
# Optional when using Anthropic as provider.
ANTHROPIC_API_KEY=

# Auth
# Required secret in production.
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
